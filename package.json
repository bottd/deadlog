{
	"name": "deadlog.io",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter 'deadlog-web' dev",
		"build": "pnpm --filter 'deadlog-web' build",
		"preview": "pnpm --filter 'deadlog-web' preview",
		"test": "pnpm --filter 'deadlog-web' test",
		"test:all": "pnpm -r --filter './app' --filter './lib/**' run test",
		"check": "pnpm --filter 'deadlog-web' check",
		"lint": "pnpm --filter 'deadlog-web' lint",
		"format": "prettier --write .",
		"fmt:check": "prettier --check .",
		"build:scraper": "tsx --tsconfig=tsconfig.base.json lib/scraper/src/cli.ts",
		"build:meta": "DATABASE_URL=file:app/static/deadlog.db tsx --tsconfig=tsconfig.base.json lib/meta/src/generate-previews.ts"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260426.1",
		"@eslint/js": "10.0.1",
		"@libsql/client": "0.17.3",
		"@lucide/svelte": "1.11.0",
		"@internationalized/date": "3.12.1",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "2.58.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/vite": "4.2.4",
		"@takumi-rs/core": "0.73.1",
		"@takumi-rs/helpers": "1.1.2",
		"@tanstack/svelte-query": "6.1.24",
		"@testing-library/jest-dom": "6.9.1",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"bits-ui": "2.18.0",
		"clsx": "2.1.1",
		"deadlock-api-client": "github:deadlock-api/openapi-clients#path:typescript/api",
		"drizzle-kit": "0.31.10",
		"drizzle-orm": "0.45.2",
		"drizzle-zod": "0.8.3",
		"eslint": "10.2.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"globals": "17.5.0",
		"happy-dom": "20.9.0",
		"mode-watcher": "1.1.0",
		"msw": "2.13.6",
		"playwright": "1.59.1",
		"prettier": "3.8.3",
		"prettier-plugin-sql": "0.20.0",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.3",
		"react": "19.2.5",
		"runed": "0.37.1",
		"svelte": "5.55.5",
