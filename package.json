{
	"name": "deadlog.io",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter 'deadlog-web' dev",
		"build": "pnpm --filter 'deadlog-web' build",
		"preview": "pnpm --filter 'deadlog-web' preview",
		"test": "pnpm run test:all",
		"test:all": "pnpm -r --if-present run test",
		"test:e2e": "pnpm --filter 'deadlog-web' test:e2e",
		"check": "pnpm --filter 'deadlog-web' check",
		"lint": "pnpm --filter 'deadlog-web' lint",
		"format": "prettier --write .",
		"fmt:check": "prettier --check .",
		"build:scraper": "tsx --tsconfig=tsconfig.base.json lib/scraper/src/cli.ts",
		"build:db": "tsx --tsconfig=tsconfig.base.json lib/scraper/src/build-db.ts",
		"build:meta": "DATABASE_URL=file:app/static/deadlog.db tsx --tsconfig=tsconfig.base.json lib/meta/src/generate-previews.ts"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "5.20260724.1",
		"@counterscale/tracker": "3.4.1",
		"@eslint/js": "10.0.1",
		"@internationalized/date": "3.12.2",
		"@libsql/client": "0.17.4",
		"@lucide/svelte": "1.26.0",
		"@sveltejs/adapter-cloudflare": "7.2.9",
		"@sveltejs/adapter-node": "5.5.7",
		"@sveltejs/kit": "2.70.1",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@tailwindcss/vite": "4.3.3",
		"@takumi-rs/core": "2.4.2",
		"@takumi-rs/helpers": "2.4.2",
		"@tanstack/svelte-query": "6.1.38",
		"@testing-library/jest-dom": "7.0.0",
		"@types/node": "26.1.1",
		"@types/react": "19.2.17",
		"@vitest/browser": "4.1.10",
		"@vitest/browser-playwright": "4.1.10",
		"bits-ui": "2.18.1",
		"clsx": "2.1.1",
		"deadlock-api-client": "github:deadlock-api/openapi-clients#path:typescript",
		"drizzle-kit": "0.31.10",
		"drizzle-orm": "0.45.2",
		"drizzle-zod": "0.8.3",
		"eslint": "10.7.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.22.0",
		"globals": "17.7.0",
		"happy-dom": "20.11.1",
		"mode-watcher": "1.1.0",
		"msw": "2.15.0",
		"playwright": "1.61.1",
		"prettier": "3.9.6",
		"prettier-plugin-sql": "0.20.0",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.1",
		"react": "19.2.8",
		"runed": "0.37.1",
		"svelte": "5.56.7",
		"svelte-check": "4.7.3",
		"svelte-meta-tags": "5.0.2",
		"svelte-sonner": "1.1.1",
		"tailwind-merge": "3.6.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.3.3",
		"tsx": "4.23.1",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.3",
