		"svelte-sonner": "1.1.1",
		"tailwind-merge": "3.5.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.2.4",
		"tsx": "4.21.0",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.0",
		"vite": "8.0.10",
		"vite-plugin-norg": "4.0.11",
		"vite-tsconfig-paths": "6.1.1",
		"@vitest/browser": "4.1.5",
